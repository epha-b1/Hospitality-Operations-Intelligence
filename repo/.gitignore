node_modules/
dist/
.env

# Log files — both rotated production logs and ad-hoc test/debug logs
# (e.g. .tmp-api.log produced when piping jest output to a file). These
# must never be committed: they leak request traces, user agents, IP
# addresses, and timing information that has no business in version
# control. The pattern is intentionally broad so any new *.log file
# anywhere in the tree is gitignored by default.
*.log
.tmp-*.log

uploads/*
exports/*
# face-templates/ stores encrypted biometric material written at
# runtime (see src/services/face.service.ts). These files MUST NEVER
# be committed. Belt + braces: ignore everything in the directory
# except the .gitkeep sentinel, and additionally ignore any stray
# `.enc` file anywhere in the tree.
face-templates/*
!uploads/.gitkeep
!exports/.gitkeep
!face-templates/.gitkeep
*.enc

# Import staging area — raw validated rows live here until commitBatch
# moves them into the DB. Never commit these and never reuse another
# directory (e.g. exports/) for them. See src/services/import.service.ts.
var/
!var/.gitkeep
